<!DOCTYPE html>
<html>
<head>
  <title><%= Util.is_prod? ? '' : 'DEV - ' %>Makerspace Authorization</title>
  <%= favicon_link_tag asset_path('favicon.png'), :rel => 'icon', :type =>  'image/png' %>
  <%= favicon_link_tag asset_path('favicon.png'), :rel => 'apple-touch-icon', :type =>  'image/png' %>
  <%= stylesheet_link_tag 'application' %>
  <meta
    name="viewport"
    content="minimum-scale=1, initial-scale=1, width=device-width, shrink-to-fit=no"
  />
  </head>
<% if ENV['BGCOLOR'] %>
<body BGCOLOR="<%= ENV['BGCOLOR'] %>">
<% else %>
<body>
<% end %>
<% unless Util.is_prod? %>
  <div class="watermark">
    DEVELOPMENT
    | Braintree: <%= ENV.fetch('BT_ENV', 'unknown') %>
    | Rails: <%= Rails.env %>
    | Rack: <%= ENV.fetch('RACK_ENV', 'unknown') %>
  </div>
<% end %>
  <%= javascript_include_tag 'application' %>
</body>
</html>
